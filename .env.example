# Copy to .env and fill values
# SMTP server settings
# Example values — copy to .env and replace with your real account credentials.
# Note: many providers use port 587 (STARTTLS) or 465 (SSL). 993 is IMAP and will not work.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=REPLACE_ME

# Destination email address (recipient)
TO_EMAIL=recipient@example.com

# Optional: FROM address used in the message 'from' header
FROM_EMAIL=you@example.com
